{
  "name": "@kagura/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=../../.env.local --import tsx --watch src/index.ts",
    "migrate": "node --env-file-if-exists=../../.env.local --import tsx src/migrate.ts",
    "build": "tsup && node scripts/verify-runtime-bundle.mjs",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@kagura/config": "workspace:*",
    "@kagura/contracts": "workspace:*",
    "@kagura/database": "workspace:*",
    "pino": "10.3.1",
    "redis": "6.1.0"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "tsup": "8.5.1",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
