{
  "extends": "../../packages/config/typescript/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@kagula/auth/*": ["../../packages/auth/src/*.ts"],
      "@kagula/config/*": ["../../packages/config/src/*.ts"],
      "@kagula/contracts/*": ["../../packages/contracts/src/*.ts"],
      "@kagula/database/*": ["../../packages/database/src/*.ts"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "next.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules"]
}
