NODE_ENV=development
APP_URL=http://localhost:3000
APP_TIMEZONE=Asia/Shanghai
APP_RELEASE=local
LOG_LEVEL=debug

SESSION_SECRET=local_only_session_secret_change_before_use
SESSION_COOKIE_NAME=kagura_session
SESSION_TTL_HOURS=168

WEB_PORT=3000
WORKER_PORT=3001

POSTGRES_DB=kagura_blog
POSTGRES_USER=kagura
POSTGRES_PASSWORD=kagura_local_only_password
POSTGRES_PORT=55432
DATABASE_URL=postgresql://kagura:kagura_local_only_password@localhost:55432/kagura_blog

REDIS_PORT=56379
REDIS_URL=redis://localhost:56379/0

MINIO_API_PORT=59000
MINIO_CONSOLE_PORT=59001
MINIO_ROOT_USER=kagura-local
MINIO_ROOT_PASSWORD=kagura_local_minio_password

R2_ENDPOINT=http://localhost:59000
R2_REGION=us-east-1
R2_BUCKET=kagura-assets
R2_PUBLIC_BASE_URL=http://localhost:59000/kagura-assets
R2_ACCESS_KEY_ID=kagura-local
R2_SECRET_ACCESS_KEY=kagura_local_minio_password
R2_FORCE_PATH_STYLE=true
MEDIA_MAX_BYTES=10485760
MEDIA_MAX_DIMENSION=8192

TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
